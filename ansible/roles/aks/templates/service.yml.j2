---
# Redis service (ClusterIP)
apiVersion: v1
kind: Service
metadata:
  name: {{ back_service_name }}
  namespace: {{ k8s_namespace }}
spec:
  selector:
    app: {{ back_deployment_name }}
  type: ClusterIP
  ports:
  - protocol: TCP
    port: 6379
    targetPort: 6379

---
# Frontend service (LoadBalancer)
apiVersion: v1
kind: Service
metadata:
  name: {{ front_service_name }}
  namespace: {{ k8s_namespace }}
spec:
  selector:
    app: {{ front_deployment_name }}
  type: LoadBalancer
  ports:
  - protocol: TCP
    port: {{ front_service_port }}
    targetPort: 80
